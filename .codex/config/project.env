PROJECT_NAME="vaulthalla"
PACKAGE_MANAGER="pnpm"

# Paths
ROOT_DIR="."
CORE_DIR="core"
WEB_DIR="web"
DEPLOY_DIR="deploy"
DEBIAN_DIR="debian"
TOOLS_DIR="tools"
BIN_DIR="bin"
CONTEXT_DIR=".codex/context"

# Web commands
WEB_DEV_CMD="pnpm dev"
WEB_BUILD_CMD="pnpm build"
WEB_TYPECHECK_CMD="pnpm typecheck"
WEB_LINT_CMD="pnpm lint"
WEB_TEST_CMD="pnpm test"

# Release tooling commands
RELEASE_CHECK_CMD="python3 -m tools.release check"
RELEASE_SYNC_DRY_RUN_CMD="python3 -m tools.release sync --dry-run"

# Common command aliases (default to web profile)
DEV_CMD="$WEB_DEV_CMD"
BUILD_CMD="$WEB_BUILD_CMD"
TYPECHECK_CMD="$WEB_TYPECHECK_CMD"
LINT_CMD="$WEB_LINT_CMD"
