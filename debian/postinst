#!/bin/sh
set -e

# postinst for vaulthalla
# - Creates system user/group + runtime dirs
# - Performs conservative optional local PostgreSQL bootstrap when available
# - Performs conservative optional nginx integration when available
# - Does NOT prompt routinely during install (except explicit DB recovery choice when preserved local DB resources already exist)
# - Does NOT perform package-time super-admin UID binding
#
# Advanced opt-outs:
#   VH_SKIP_DB_BOOTSTRAP=1
#   VH_SKIP_NGINX_CONFIG=1

PKG="vaulthalla"
DB_USER="vaulthalla"
DB_NAME="vaulthalla"
LEGACY_PENDING_SUPERADMIN_UID_FILE="/run/vaulthalla/superadmin_uid"
PENDING_DB_PASS_FILE="/run/vaulthalla/db_password"
CORE_SYSTEMD_UNIT="vaulthalla.service"
CLI_SYSTEMD_UNIT="vaulthalla-cli.service"
CLI_SOCKET_SYSTEMD_UNIT="vaulthalla-cli.socket"
WEB_SYSTEMD_UNIT="vaulthalla-web.service"
SWTPM_SYSTEMD_UNIT="vaulthalla-swtpm.service"
PSQL_DEPLOY_DIR="/usr/share/vaulthalla/psql"
NGINX_TEMPLATE="/usr/share/vaulthalla/nginx/vaulthalla"
NGINX_SITE_AVAIL="/etc/nginx/sites-available/vaulthalla"
NGINX_SITE_ENABLED="/etc/nginx/sites-enabled/vaulthalla"
NGINX_MANAGED_MARKER="/var/lib/vaulthalla/nginx_site_managed"
SWTPM_BASE_DIR="/var/lib/swtpm"
SWTPM_STATE_DIR="${SWTPM_BASE_DIR}/vaulthalla"
TPM_BACKEND_OVERRIDE_DIR="/etc/systemd/system/vaulthalla.service.d"
TPM_BACKEND_OVERRIDE_FILE="${TPM_BACKEND_OVERRIDE_DIR}/tpm-backend.conf"
APPARMOR_SWTPM_PROFILE=""
APPARMOR_SWTPM_LOCAL_OVERRIDE=""

DB_BOOTSTRAP_STATUS="skipped"
NGINX_CONFIG_STATUS="skipped"
TPM_BACKEND_STATUS="unknown"
POSTINST_ACTION="${1:-}"
LAST_CONFIGURED_VERSION="${2:-}"

create_dir() {
    # create_dir path mode owner group
    install -d -m "$2" -o "$3" -g "$4" "$1"
}

is_upgrade() {
    [ "$POSTINST_ACTION" = "configure" ] && [ -n "$LAST_CONFIGURED_VERSION" ]
}

has_command() {
    command -v "$1" >/dev/null 2>&1
}

safe_systemctl() {
    if ! has_command systemctl; then
        return 0
    fi
    systemctl --system "$@" >/dev/null 2>&1 || true
}

run_as_postgres() {
    if has_command runuser; then
        runuser -u postgres -- "$@"
        return $?
    fi
    if has_command sudo; then
        sudo -u postgres "$@"
        return $?
    fi
    return 1
}

env_flag_enabled() {
    case "$1" in
        1|true|TRUE|yes|YES|on|ON)
            return 0
            ;;
        *)
            return 1
            ;;
    esac
}

psql_q() {
    # psql_q "SQL" [database]
    run_as_postgres psql -X -v ON_ERROR_STOP=1 -tAc "$1" "${2:-postgres}"
}

postgresql_server_ready() {
    if has_command pg_isready; then
        run_as_postgres pg_isready -q >/dev/null 2>&1
        return $?
    fi
    run_as_postgres psql -X -v ON_ERROR_STOP=1 -d postgres -tAc 'SELECT 1' >/dev/null 2>&1
}

ensure_tss_group_and_user_added() {
    if getent group tss > /dev/null; then
        echo "[${PKG}] Ensuring '${DB_USER}' is a member of the existing 'tss' group."
    else
        echo "[${PKG}] No 'tss' group found; creating one."
        addgroup --system tss
    fi
    if id -nG "$DB_USER" 2>/dev/null | tr ' ' '\n' | grep -qx tss; then
        return 0
    fi
    adduser "$DB_USER" tss
}

align_config_file_permissions() {
    target="$1"
    if [ ! -f "$target" ]; then
        return 0
    fi
    chown "$DB_USER:$DB_USER" "$target"
    chmod 0640 "$target"
}

ensure_fuse_allow_other() {
    fuse_conf="/etc/fuse.conf"
    if [ ! -f "$fuse_conf" ]; then
        install -m 0644 /dev/null "$fuse_conf"
    fi

    if grep -Eq '^[[:space:]]*user_allow_other([[:space:]]*(#.*)?)?$' "$fuse_conf"; then
        echo "[${PKG}] FUSE config: user_allow_other already enabled"
        return 0
    fi

    if grep -Eq '^[[:space:]]*#[[:space:]]*user_allow_other([[:space:]]*(#.*)?)?$' "$fuse_conf"; then
        sed -i -E 's/^[[:space:]]*#[[:space:]]*(user_allow_other([[:space:]]*(#.*)?)?)$/\1/' "$fuse_conf"
        echo "[${PKG}] FUSE config: enabled user_allow_other in /etc/fuse.conf"
        return 0
    fi

    printf '\nuser_allow_other\n' >> "$fuse_conf"
    echo "[${PKG}] FUSE config: enabled user_allow_other in /etc/fuse.conf"
}

require_runtime_assets() {
    if [ ! -d "$PSQL_DEPLOY_DIR" ]; then
        echo "[${PKG}] ERROR: Required SQL deploy directory is missing: ${PSQL_DEPLOY_DIR}" >&2
        exit 1
    fi

    if ! find "$PSQL_DEPLOY_DIR" -maxdepth 1 -type f -name '*.sql' | grep -q .; then
        echo "[${PKG}] ERROR: SQL deploy directory is empty: ${PSQL_DEPLOY_DIR}" >&2
        exit 1
    fi
}

refresh_tpm_udev_rules() {
    if ! has_command udevadm; then
        return 0
    fi
    udevadm control --reload-rules >/dev/null 2>&1 || true
    udevadm trigger --subsystem-match=tpm >/dev/null 2>&1 || true
}

has_hardware_tpm() {
    [ -c /dev/tpmrm0 ] || [ -c /dev/tpm0 ]
}

swtpm_listening_locally() {
    if ! has_command ss; then
        return 0
    fi
    ss -H -ltn '( sport = :2321 )' 2>/dev/null | grep -q '127.0.0.1:2321'
}

clear_tpm_backend_override() {
    rm -f "$TPM_BACKEND_OVERRIDE_FILE"
}

write_swtpm_tcti_override() {
    install -d -m 0755 "$TPM_BACKEND_OVERRIDE_DIR"
    cat > "$TPM_BACKEND_OVERRIDE_FILE" <<EOF
[Service]
Environment=TSS2_TCTI=swtpm:host=127.0.0.1,port=2321
EOF
    chmod 0644 "$TPM_BACKEND_OVERRIDE_FILE"
}

find_swtpm_apparmor_profile() {
    APPARMOR_SWTPM_PROFILE=""
    for candidate in /etc/apparmor.d/usr.bin.swtpm /etc/apparmor.d/swtpm; do
        if [ -f "$candidate" ]; then
            APPARMOR_SWTPM_PROFILE="$candidate"
            return 0
        fi
    done
    return 1
}

resolve_swtpm_apparmor_local_override() {
    profile_path="$1"
    APPARMOR_SWTPM_LOCAL_OVERRIDE=""
    include_rel="$(sed -n 's/^[[:space:]]*#include[[:space:]]*<\(local\/[^>]*\)>.*/\1/p' "$profile_path" | head -n 1)"
    if [ -n "$include_rel" ]; then
        APPARMOR_SWTPM_LOCAL_OVERRIDE="/etc/apparmor.d/${include_rel}"
        return 0
    fi

    case "$(basename "$profile_path")" in
        usr.bin.swtpm)
            APPARMOR_SWTPM_LOCAL_OVERRIDE="/etc/apparmor.d/local/usr.bin.swtpm"
            ;;
        swtpm)
            APPARMOR_SWTPM_LOCAL_OVERRIDE="/etc/apparmor.d/local/swtpm"
            ;;
        *)
            APPARMOR_SWTPM_LOCAL_OVERRIDE="/etc/apparmor.d/local/usr.bin.swtpm"
            ;;
    esac
    return 0
}

append_unique_line() {
    target_file="$1"
    target_line="$2"
    if grep -Fqx "$target_line" "$target_file" 2>/dev/null; then
        return 0
    fi
    printf '%s\n' "$target_line" >> "$target_file"
    APPARMOR_OVERRIDE_CHANGED="1"
}

configure_swtpm_apparmor_override_if_possible() {
    APPARMOR_OVERRIDE_CHANGED="0"

    if [ ! -d /sys/module/apparmor ]; then
        echo "[${PKG}] WARNING: AppArmor module not detected; skipping swtpm AppArmor override handling."
        return 1
    fi

    if ! find_swtpm_apparmor_profile; then
        echo "[${PKG}] WARNING: swtpm AppArmor profile not found; skipping local override."
        return 1
    fi
    resolve_swtpm_apparmor_local_override "$APPARMOR_SWTPM_PROFILE"
    install -d -m 0755 "$(dirname "$APPARMOR_SWTPM_LOCAL_OVERRIDE")"
    if [ ! -f "$APPARMOR_SWTPM_LOCAL_OVERRIDE" ]; then
        : > "$APPARMOR_SWTPM_LOCAL_OVERRIDE"
        chmod 0644 "$APPARMOR_SWTPM_LOCAL_OVERRIDE"
    fi

    append_unique_line "$APPARMOR_SWTPM_LOCAL_OVERRIDE" "# Allow Vaulthalla-managed swtpm state."
    append_unique_line "$APPARMOR_SWTPM_LOCAL_OVERRIDE" "${SWTPM_STATE_DIR}/ rw,"
    append_unique_line "$APPARMOR_SWTPM_LOCAL_OVERRIDE" "${SWTPM_STATE_DIR}/** rwk,"

    if [ "$APPARMOR_OVERRIDE_CHANGED" = "1" ]; then
        echo "[${PKG}] Installed swtpm AppArmor local override at ${APPARMOR_SWTPM_LOCAL_OVERRIDE}."
    else
        echo "[${PKG}] swtpm AppArmor local override already includes Vaulthalla state rules."
    fi

    if ! has_command apparmor_parser; then
        echo "[${PKG}] WARNING: apparmor_parser is unavailable; cannot reload swtpm AppArmor profile." >&2
        return 1
    fi

    if ! apparmor_parser -r "$APPARMOR_SWTPM_PROFILE" >/dev/null 2>&1; then
        echo "[${PKG}] WARNING: Failed to reload AppArmor profile: ${APPARMOR_SWTPM_PROFILE}" >&2
        return 1
    fi

    echo "[${PKG}] Reloaded AppArmor profile: ${APPARMOR_SWTPM_PROFILE}."
    return 0
}

start_and_validate_swtpm_service() {
    if ! systemctl --system enable --now "$SWTPM_SYSTEMD_UNIT" >/dev/null 2>&1; then
        return 1
    fi
    if ! systemctl --system --quiet is-active "$SWTPM_SYSTEMD_UNIT" >/dev/null 2>&1; then
        return 1
    fi
    if ! swtpm_listening_locally; then
        return 1
    fi
    return 0
}

configure_tpm_backend_if_safe() {
    if has_hardware_tpm; then
        TPM_BACKEND_STATUS="hardware (device-backed TPM detected)"
        echo "[${PKG}] TPM backend: hardware TPM detected (/dev/tpmrm0 or /dev/tpm0)."
        clear_tpm_backend_override
        safe_systemctl stop "$SWTPM_SYSTEMD_UNIT"
        safe_systemctl disable "$SWTPM_SYSTEMD_UNIT"
        return 0
    fi

    echo "[${PKG}] TPM backend: no hardware TPM detected; provisioning Vaulthalla swtpm backend."

    if ! has_command swtpm; then
        TPM_BACKEND_STATUS="error (no hardware TPM and swtpm not installed)"
        echo "[${PKG}] ERROR: No hardware TPM device was detected and 'swtpm' is not installed." >&2
        echo "[${PKG}] ERROR: Install swtpm backend packages and re-run configure:" >&2
        echo "[${PKG}] ERROR:   sudo apt install swtpm swtpm-tools" >&2
        return 1
    fi

    create_dir "$SWTPM_BASE_DIR" 755 root root
    create_dir "$SWTPM_STATE_DIR" 700 "$DB_USER" "$DB_USER"
    write_swtpm_tcti_override

    if ! has_command systemctl; then
        TPM_BACKEND_STATUS="swtpm configured (systemctl unavailable; runtime activation not verified)"
        echo "[${PKG}] WARNING: systemctl unavailable; cannot verify ${SWTPM_SYSTEMD_UNIT} runtime state."
        return 0
    fi

    if ! systemctl --system daemon-reload >/dev/null 2>&1; then
        TPM_BACKEND_STATUS="error (failed daemon-reload for swtpm backend)"
        echo "[${PKG}] ERROR: Failed to reload systemd while configuring swtpm backend." >&2
        return 1
    fi

    if start_and_validate_swtpm_service; then
        TPM_BACKEND_STATUS="swtpm (managed fallback active)"
        echo "[${PKG}] TPM backend: managed swtpm fallback active."
        return 0
    fi

    echo "[${PKG}] WARNING: ${SWTPM_SYSTEMD_UNIT} failed initial start; checking AppArmor local override path."

    if configure_swtpm_apparmor_override_if_possible; then
        systemctl --system reset-failed "$SWTPM_SYSTEMD_UNIT" >/dev/null 2>&1 || true
        if start_and_validate_swtpm_service; then
            TPM_BACKEND_STATUS="swtpm (managed fallback active; AppArmor local override applied)"
            echo "[${PKG}] TPM backend: managed swtpm fallback active after AppArmor override reload."
            return 0
        fi
    fi

    TPM_BACKEND_STATUS="error (failed to start ${SWTPM_SYSTEMD_UNIT})"
    echo "[${PKG}] ERROR: Failed to start ${SWTPM_SYSTEMD_UNIT}." >&2
    echo "[${PKG}] ERROR: Check logs with: journalctl -u ${SWTPM_SYSTEMD_UNIT}" >&2
    if [ -n "$APPARMOR_SWTPM_LOCAL_OVERRIDE" ]; then
        echo "[${PKG}] ERROR: Check AppArmor local override: ${APPARMOR_SWTPM_LOCAL_OVERRIDE}" >&2
    fi
    echo "[${PKG}] ERROR: Last-resort debug command (not default packaging behavior):" >&2
    echo "[${PKG}] ERROR:   sudo aa-complain swtpm || sudo aa-complain /usr/bin/swtpm" >&2
    return 1
}

is_noninteractive_context() {
    if [ "${DEBIAN_FRONTEND:-}" = "noninteractive" ]; then
        return 0
    fi
    if [ ! -t 0 ] || [ ! -t 1 ]; then
        return 0
    fi
    return 1
}

read_interactive_line() {
    INTERACTIVE_INPUT=""
    if [ -r /dev/tty ]; then
        IFS= read -r INTERACTIVE_INPUT </dev/tty || true
    else
        IFS= read -r INTERACTIVE_INPUT || true
    fi
}

write_pending_db_password() {
    db_password="$1"
    umask 077
    printf '%s\n' "$db_password" > "$PENDING_DB_PASS_FILE"
    chown "$DB_USER:$DB_USER" "$PENDING_DB_PASS_FILE"
    chmod 0600 "$PENDING_DB_PASS_FILE"
}

sql_escape_literal() {
    printf '%s' "$1" | sed "s/'/''/g"
}

print_db_recovery_menu() {
    printf '\n%s\n\n' "Existing Vaulthalla PostgreSQL resources were detected."
    printf '%s\n\n' "Choose how to proceed:"
    printf '%s\n' "  1. Reuse existing database"
    printf '%s\n' "     Provide the existing PostgreSQL role password exported before uninstall."
    printf '%s\n' "     Vaulthalla will place it in /run/vaulthalla/db_password so the service can"
    printf '%s\n\n' "     consume it on startup and restore the runtime TPM-backed secret."
    printf '%s\n' "  2. Drop and recreate Vaulthalla database/role"
    printf '%s\n\n' "     DANGER: This permanently deletes the existing local Vaulthalla database."
    printf '%s\n\n' "  3. Exit without changing PostgreSQL resources"
    printf '%s' "Select [1-3]: "
}

print_db_recovery_exit_instructions() {
    printf '%s\n' "Reuse preserved database:"
    printf '%s\n' "  provide the exported PostgreSQL role password during install, or manually seed:"
    printf '%s\n' "  sudo install -d -m 0755 /run/vaulthalla"
    printf '%s\n' "  sudo install -m 0600 -o vaulthalla -g vaulthalla /path/to/db_password /run/vaulthalla/db_password"
    printf '%s\n' "  sudo systemctl restart vaulthalla"
    printf '\n'
    printf '%s\n' "Fresh install:"
    printf '%s\n' "  sudo vh teardown db"
    printf '%s\n' "  sudo vh setup db"
}

collect_reuse_password_from_file() {
    attempts=0
    while [ "$attempts" -lt 3 ]; do
        attempts=$((attempts + 1))
        printf '%s' "Password file path: "
        read_interactive_line
        PASSWORD_FILE_PATH="$(printf '%s' "$INTERACTIVE_INPUT" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"

        if [ -z "$PASSWORD_FILE_PATH" ]; then
            echo "[${PKG}] Empty password file path. Try again."
            continue
        fi
        if [ ! -f "$PASSWORD_FILE_PATH" ]; then
            echo "[${PKG}] Password file does not exist or is not a regular file: ${PASSWORD_FILE_PATH}"
            continue
        fi
        if [ ! -s "$PASSWORD_FILE_PATH" ]; then
            echo "[${PKG}] Password file is empty: ${PASSWORD_FILE_PATH}"
            continue
        fi

        PASSWORD_FILE_LINE="$(sed -n '1p' "$PASSWORD_FILE_PATH" 2>/dev/null || true)"
        RECOVERY_DB_PASSWORD="$(printf '%s' "$PASSWORD_FILE_LINE" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')"
        if [ -z "$RECOVERY_DB_PASSWORD" ]; then
            echo "[${PKG}] Password file first line is empty after trimming: ${PASSWORD_FILE_PATH}"
            continue
        fi
        return 0
    done

    DB_BOOTSTRAP_STATUS="deferred (existing DB selected for reuse, but password file validation failed)"
    echo "[${PKG}] Failed to validate password file after multiple attempts. Preserving PostgreSQL resources."
    print_db_recovery_exit_instructions
    return 1
}

perform_fresh_local_db_bootstrap() {
    if ! has_command openssl; then
        DB_BOOTSTRAP_STATUS="skipped (openssl not installed for role password generation)"
        return 0
    fi

    VAUL_PG_PASS="$(openssl rand -base64 32 | tr -d '\n')"
    ESCAPED_PASS="$(sql_escape_literal "$VAUL_PG_PASS")"

    if ! run_as_postgres psql -X -v ON_ERROR_STOP=1 postgres <<EOF
CREATE ROLE ${DB_USER} LOGIN PASSWORD '${ESCAPED_PASS}';
EOF
    then
        DB_BOOTSTRAP_STATUS="skipped (failed creating PostgreSQL role '${DB_USER}')"
        return 0
    fi
    echo "[${PKG}] Created PostgreSQL role '${DB_USER}'."

    if ! run_as_postgres psql -X -v ON_ERROR_STOP=1 -c "CREATE DATABASE ${DB_NAME} OWNER ${DB_USER};" postgres; then
        DB_BOOTSTRAP_STATUS="skipped (failed creating PostgreSQL database '${DB_NAME}')"
        return 0
    fi
    echo "[${PKG}] Created PostgreSQL database '${DB_NAME}'."

    if ! run_as_postgres psql -X -v ON_ERROR_STOP=1 -c "GRANT ALL PRIVILEGES ON DATABASE ${DB_NAME} TO ${DB_USER};" postgres; then
        DB_BOOTSTRAP_STATUS="skipped (failed granting DB privileges)"
        return 0
    fi

    write_pending_db_password "$VAUL_PG_PASS"
    DB_BOOTSTRAP_STATUS="done (created local DB role/database and seeded runtime password handoff at ${PENDING_DB_PASS_FILE})"
    return 0
}

reuse_existing_db_with_handoff_seed() {
    role_exists="$1"
    db_exists="$2"
    role_created="false"
    db_created="false"

    if ! collect_reuse_password_from_file; then
        return 0
    fi

    ESCAPED_PASS="$(sql_escape_literal "$RECOVERY_DB_PASSWORD")"

    if [ "$role_exists" != "1" ]; then
        if ! run_as_postgres psql -X -v ON_ERROR_STOP=1 postgres <<EOF
CREATE ROLE ${DB_USER} LOGIN PASSWORD '${ESCAPED_PASS}';
EOF
        then
            DB_BOOTSTRAP_STATUS="deferred (existing DB reuse failed while creating missing role '${DB_USER}')"
            echo "[${PKG}] Preserving existing PostgreSQL state. Manual recovery required."
            return 0
        fi
        role_created="true"
        echo "[${PKG}] Created missing PostgreSQL role '${DB_USER}' for reuse path."
    fi

    if [ "$db_exists" != "1" ]; then
        if ! run_as_postgres psql -X -v ON_ERROR_STOP=1 -c "CREATE DATABASE ${DB_NAME} OWNER ${DB_USER};" postgres; then
            DB_BOOTSTRAP_STATUS="deferred (existing DB reuse failed while creating missing database '${DB_NAME}')"
            echo "[${PKG}] Preserving existing PostgreSQL state. Manual recovery required."
            return 0
        fi
        db_created="true"
        echo "[${PKG}] Created missing PostgreSQL database '${DB_NAME}' for reuse path."
    fi

    if ! run_as_postgres psql -X -v ON_ERROR_STOP=1 -c "GRANT ALL PRIVILEGES ON DATABASE ${DB_NAME} TO ${DB_USER};" postgres; then
        DB_BOOTSTRAP_STATUS="deferred (existing DB reuse failed while granting DB privileges)"
        echo "[${PKG}] Preserving existing PostgreSQL state. Manual recovery required."
        return 0
    fi

    if [ "$role_created" = "true" ] && [ "$db_created" = "false" ]; then
        run_as_postgres psql -X -v ON_ERROR_STOP=1 -c "ALTER DATABASE ${DB_NAME} OWNER TO ${DB_USER};" postgres >/dev/null 2>&1 || true
    fi

    write_pending_db_password "$RECOVERY_DB_PASSWORD"
    echo "[${PKG}] existing DB selected for reuse"
    echo "[${PKG}] runtime DB password handoff seeded at ${PENDING_DB_PASS_FILE}"
    echo "[${PKG}] service startup will consume and seal the password through normal runtime flow"
    DB_BOOTSTRAP_STATUS="done (existing DB selected for reuse; runtime DB password handoff seeded)"
    return 0
}

drop_and_recreate_existing_db() {
    confirm_phrase="DROP VAULTHALLA DATABASE"
    printf '\n%s\n' "Type the following phrase exactly to confirm destructive recreate:"
    printf '%s\n' "  ${confirm_phrase}"
    printf '%s' "Confirmation: "
    read_interactive_line

    if [ "$INTERACTIVE_INPUT" != "$confirm_phrase" ]; then
        DB_BOOTSTRAP_STATUS="deferred (destructive recreate aborted; confirmation phrase did not match)"
        echo "[${PKG}] Destructive recreate aborted. PostgreSQL resources were not changed."
        print_db_recovery_exit_instructions
        return 0
    fi

    if ! run_as_postgres psql -X -v ON_ERROR_STOP=1 postgres <<EOF
SELECT pg_terminate_backend(pid) FROM pg_stat_activity WHERE datname='${DB_NAME}' AND pid <> pg_backend_pid();
DROP DATABASE IF EXISTS ${DB_NAME};
DROP ROLE IF EXISTS ${DB_USER};
EOF
    then
        DB_BOOTSTRAP_STATUS="deferred (failed dropping existing PostgreSQL resources for destructive recreate)"
        echo "[${PKG}] Failed to drop existing PostgreSQL resources. Preserving current state."
        return 0
    fi

    echo "[${PKG}] Existing PostgreSQL database/role destroyed after explicit confirmation."
    perform_fresh_local_db_bootstrap
    return 0
}

handle_existing_local_db_resources() {
    role_exists="$1"
    db_exists="$2"

    if is_noninteractive_context; then
        DB_BOOTSTRAP_STATUS="deferred (existing local DB resources detected in noninteractive install; preserved without password reseed)"
        echo "[${PKG}] Existing Vaulthalla PostgreSQL resources detected in noninteractive install."
        echo "[${PKG}] Preserving database and role. Runtime DB password was not reseeded."
        echo "[${PKG}] To reuse this database, seed ${PENDING_DB_PASS_FILE} with the exported role password and restart Vaulthalla."
        echo "[${PKG}] To start fresh, run the destructive DB teardown/setup commands manually."
        print_db_recovery_exit_instructions
        return 0
    fi

    while true; do
        print_db_recovery_menu
        read_interactive_line
        choice="$(printf '%s' "$INTERACTIVE_INPUT" | tr -d '[:space:]')"

        case "$choice" in
            1)
                reuse_existing_db_with_handoff_seed "$role_exists" "$db_exists"
                return 0
                ;;
            2)
                drop_and_recreate_existing_db
                return 0
                ;;
            3)
                DB_BOOTSTRAP_STATUS="deferred (operator exited DB recovery prompt without changing PostgreSQL resources)"
                print_db_recovery_exit_instructions
                return 0
                ;;
            *)
                echo "[${PKG}] Invalid selection '$choice'. Please enter 1, 2, or 3."
                ;;
        esac
    done
}

bootstrap_db_if_safe() {
    if env_flag_enabled "${VH_SKIP_DB_BOOTSTRAP:-}"; then
        DB_BOOTSTRAP_STATUS="skipped (VH_SKIP_DB_BOOTSTRAP=1)"
        return 0
    fi

    if ! has_command psql; then
        DB_BOOTSTRAP_STATUS="skipped (psql not installed; install PostgreSQL or configure remote DB)"
        return 0
    fi
    if ! id postgres >/dev/null 2>&1; then
        DB_BOOTSTRAP_STATUS="skipped (local postgres user missing; likely remote/lean install)"
        return 0
    fi
    if ! run_as_postgres true >/dev/null 2>&1; then
        DB_BOOTSTRAP_STATUS="skipped (cannot execute as postgres user)"
        return 0
    fi
    if ! postgresql_server_ready; then
        DB_BOOTSTRAP_STATUS="skipped (local PostgreSQL server not ready)"
        return 0
    fi

    if ! ROLE_EXISTS="$(psql_q "SELECT 1 FROM pg_roles WHERE rolname='${DB_USER}'")"; then
        DB_BOOTSTRAP_STATUS="skipped (failed to query PostgreSQL role state)"
        return 0
    fi
    ROLE_EXISTS="$(printf '%s' "$ROLE_EXISTS" | tr -d '[:space:]')"

    if ! DB_EXISTS="$(psql_q "SELECT 1 FROM pg_database WHERE datname='${DB_NAME}'")"; then
        DB_BOOTSTRAP_STATUS="skipped (failed to query PostgreSQL database state)"
        return 0
    fi
    DB_EXISTS="$(printf '%s' "$DB_EXISTS" | tr -d '[:space:]')"

    if [ "$ROLE_EXISTS" = "1" ] || [ "$DB_EXISTS" = "1" ]; then
        if is_upgrade; then
            DB_BOOTSTRAP_STATUS="reused (existing local DB resources preserved during upgrade)"
            echo "[${PKG}] Existing Vaulthalla PostgreSQL resources detected during upgrade; preserving role/database state."
            echo "[${PKG}] Runtime DB password reseed is skipped during upgrade."
            return 0
        fi
        handle_existing_local_db_resources "$ROLE_EXISTS" "$DB_EXISTS"
        return 0
    fi

    perform_fresh_local_db_bootstrap
}

setup_web_runtime_cache() {
    WEB_ROOT="/usr/share/vaulthalla-web"
    CACHE_DIR="/var/cache/vaulthalla-web"
    CACHE_LINK="${WEB_ROOT}/.next/cache"
    CACHE_LINK_TARGET=""

    if [ ! -d "${WEB_ROOT}/.next" ]; then
        echo "[${PKG}] Web cache: skipped (${WEB_ROOT}/.next not present)."
        return 0
    fi

    install -d -m 0750 -o "$DB_USER" -g "$DB_USER" "$CACHE_DIR"

    if [ -L "$CACHE_LINK" ]; then
        CACHE_LINK_TARGET="$(readlink "$CACHE_LINK" 2>/dev/null || true)"
        if [ "$CACHE_LINK_TARGET" != "$CACHE_DIR" ]; then
            echo "[${PKG}] WARNING: Web cache link exists with unexpected target; leaving unchanged: ${CACHE_LINK} -> ${CACHE_LINK_TARGET}"
            return 0
        fi
    elif [ -e "$CACHE_LINK" ]; then
        echo "[${PKG}] WARNING: Web cache path exists and is not a symlink; leaving unchanged: ${CACHE_LINK}"
        return 0
    else
        ln -s "$CACHE_DIR" "$CACHE_LINK"
    fi

    if [ -L "$CACHE_LINK" ]; then
        chown -h "$DB_USER:$DB_USER" "$CACHE_LINK" 2>/dev/null || true
    fi

    echo "[${PKG}] Web cache: ${CACHE_LINK} -> ${CACHE_DIR}"
}

nginx_installed() {
    has_command nginx && [ -d /etc/nginx ]
}

nginx_active() {
    has_command systemctl && systemctl --quiet is-active nginx.service 2>/dev/null
}

has_non_nginx_listener_on_web_ports() {
    if ! has_command ss; then
        return 1
    fi
    WEB_LISTENERS="$(ss -H -ltnp '( sport = :80 or sport = :443 )' 2>/dev/null || true)"
    if [ -z "$WEB_LISTENERS" ]; then
        return 1
    fi
    echo "$WEB_LISTENERS" | grep -v "nginx" | grep -q .
}

has_custom_nginx_sites_enabled() {
    if [ ! -d /etc/nginx/sites-enabled ]; then
        return 1
    fi
    for entry in /etc/nginx/sites-enabled/*; do
        [ -e "$entry" ] || continue
        base="$(basename "$entry")"
        case "$base" in
            default|vaulthalla)
                ;;
            *)
                return 0
                ;;
        esac
    done
    return 1
}

configure_nginx_if_safe() {
    if env_flag_enabled "${VH_SKIP_NGINX_CONFIG:-}"; then
        NGINX_CONFIG_STATUS="skipped (VH_SKIP_NGINX_CONFIG=1)"
        return 0
    fi

    if ! nginx_installed; then
        NGINX_CONFIG_STATUS="skipped (nginx not installed; install nginx for reverse-proxy integration)"
        return 0
    fi
    if ! nginx_active; then
        NGINX_CONFIG_STATUS="skipped (nginx installed but inactive)"
        return 0
    fi
    if has_non_nginx_listener_on_web_ports; then
        NGINX_CONFIG_STATUS="skipped (non-nginx listeners active on 80/443)"
        return 0
    fi
    if has_custom_nginx_sites_enabled; then
        NGINX_CONFIG_STATUS="skipped (custom nginx site layout detected)"
        return 0
    fi
    if [ ! -f "$NGINX_TEMPLATE" ]; then
        NGINX_CONFIG_STATUS="skipped (missing packaged nginx template)"
        return 0
    fi

    install -d -m 0755 /etc/nginx/sites-available /etc/nginx/sites-enabled

    if [ ! -f "$NGINX_SITE_AVAIL" ]; then
        install -m 0644 "$NGINX_TEMPLATE" "$NGINX_SITE_AVAIL"
        printf '%s\n' "managed-by=${PKG}" > "$NGINX_MANAGED_MARKER"
        chmod 0644 "$NGINX_MANAGED_MARKER" >/dev/null 2>&1 || true
    fi

    CREATED_SITE_LINK="false"
    if [ -L "$NGINX_SITE_ENABLED" ]; then
        existing_target="$(readlink "$NGINX_SITE_ENABLED" 2>/dev/null || true)"
        case "$existing_target" in
            "$NGINX_SITE_AVAIL"|../sites-available/vaulthalla)
                :
                ;;
            *)
                NGINX_CONFIG_STATUS="skipped (${NGINX_SITE_ENABLED} symlink target is managed externally)"
                return 0
                ;;
        esac
    elif [ -e "$NGINX_SITE_ENABLED" ]; then
        NGINX_CONFIG_STATUS="skipped (${NGINX_SITE_ENABLED} exists and is not a symlink)"
        return 0
    else
        ln -s "$NGINX_SITE_AVAIL" "$NGINX_SITE_ENABLED"
        CREATED_SITE_LINK="true"
    fi

    if nginx -t >/dev/null 2>&1; then
        safe_systemctl reload nginx.service
        NGINX_CONFIG_STATUS="done (package-managed nginx site enabled)"
        return 0
    fi

    if [ "$CREATED_SITE_LINK" = "true" ]; then
        rm -f "$NGINX_SITE_ENABLED"
    fi
    NGINX_CONFIG_STATUS="skipped (nginx config test failed; reverted site enablement)"
    return 0
}

case "$1" in
  configure)
    if ! id "$DB_USER" >/dev/null 2>&1; then
        adduser --quiet --system --group --home /nonexistent --no-create-home --shell /usr/sbin/nologin "$DB_USER"
    fi

    systemd-tmpfiles --create /usr/lib/tmpfiles.d/vaulthalla.conf || true

    ensure_tss_group_and_user_added
    refresh_tpm_udev_rules

    create_dir /var/lib/vaulthalla 0700 "$DB_USER" "$DB_USER"
    create_dir /var/log/vaulthalla 0750 "$DB_USER" "$DB_USER"
    create_dir /run/vaulthalla     0750 "$DB_USER" "$DB_USER"
    install -d -m 0755 /etc/vaulthalla
    [ -d /mnt/vaulthalla ] || create_dir /mnt/vaulthalla 0755 "$DB_USER" "$DB_USER"
    setup_web_runtime_cache
    ensure_fuse_allow_other
    align_config_file_permissions /etc/vaulthalla/config.yaml
    align_config_file_permissions /etc/vaulthalla/config_template.yaml.in
    require_runtime_assets
    if ! configure_tpm_backend_if_safe; then
        if is_upgrade; then
            echo "[${PKG}] WARNING: TPM backend provisioning failed during upgrade; preserving existing TPM backend state."
            TPM_BACKEND_STATUS="${TPM_BACKEND_STATUS} (non-fatal during upgrade)"
        else
            exit 1
        fi
    fi

    # Remove any stale super-admin seed from older package revisions.
    rm -f "$LEGACY_PENDING_SUPERADMIN_UID_FILE"

    bootstrap_db_if_safe

    safe_systemctl daemon-reexec
    safe_systemctl daemon-reload
    safe_systemctl preset "$CORE_SYSTEMD_UNIT"
    safe_systemctl preset "$CLI_SOCKET_SYSTEMD_UNIT"
    safe_systemctl preset "$CLI_SYSTEMD_UNIT"
    safe_systemctl preset "$WEB_SYSTEMD_UNIT"
    safe_systemctl preset "$SWTPM_SYSTEMD_UNIT"
    safe_systemctl enable --now "$CORE_SYSTEMD_UNIT"
    safe_systemctl enable --now "$CLI_SOCKET_SYSTEMD_UNIT"
    safe_systemctl enable --now "$CLI_SYSTEMD_UNIT"
    safe_systemctl enable --now "$WEB_SYSTEMD_UNIT"

    configure_nginx_if_safe

    echo "[${PKG}] Install summary:"
    echo "[${PKG}]   DB bootstrap: ${DB_BOOTSTRAP_STATUS}"
    echo "[${PKG}]   TPM backend: ${TPM_BACKEND_STATUS}"
    echo "[${PKG}]   nginx config: ${NGINX_CONFIG_STATUS}"
    echo "[${PKG}]   Super-admin ownership: deferred to first CLI use ('vh' or 'vaulthalla')."

    #DEBHELPER#
    ;;

  abort-upgrade|abort-remove|abort-deconfigure)
    #DEBHELPER#
    ;;

  *)
    echo "postinst called with unknown argument \`$1'" >&2
    exit 1
    ;;
esac

exit 0
