[Unit]
Description=Vaulthalla Service - The Final Cloud
After=network.target postgresql.service vaulthalla-swtpm.service
Requires=postgresql.service
Wants=vaulthalla-swtpm.service

[Service]
User=vaulthalla
Group=vaulthalla
SupplementaryGroups=tss
# EnvironmentFile=/etc/vaulthalla/vaulthalla.env
ExecStart=@BINDIR@/vaulthalla-server
Restart=on-failure
RestartSec=3
LimitNOFILE=65535
SyslogIdentifier=vaulthalla
WorkingDirectory=/var/lib/vaulthalla

[Install]
WantedBy=multi-user.target
